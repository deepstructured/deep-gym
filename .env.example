# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Telegram bot (OTP login) ─────────────────────────────────────────────
# Token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Bot username without @ (shown on the login screen)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=DeepGymBot
# Random secret used to validate webhook calls from Telegram.
# Generate one: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=random-secret-string

# ── App ──────────────────────────────────────────────────────────────────
# Public origin of the app (used for OAuth redirects), e.g. https://deepgym.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
